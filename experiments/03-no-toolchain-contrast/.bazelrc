# Experiment 01: the ENTIRE BuildBuddy RBE configuration we are testing.
#
# Note what is NOT here: no --host_platform, no --platforms, no
# --extra_execution_platforms, no --exec_properties, no crosstool/toolchain
# flags. Just "point at the remote cache + executor".
#
# The API key is intentionally NOT in this file (it must never be committed).
# Pass it at the command line:
#   bazel build //:hello --remote_header=x-buildbuddy-api-key=$BUILDBUDDY_API_KEY

build --remote_executor=grpcs://remote.buildbuddy.io
build --remote_cache=grpcs://remote.buildbuddy.io

# Build event stream so we get a shareable invocation URL.
build --bes_backend=grpcs://remote.buildbuddy.io
build --bes_results_url=https://app.buildbuddy.io/invocation/

# Helpful, not strictly required.
build --remote_timeout=600
